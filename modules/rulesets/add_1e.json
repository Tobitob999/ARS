  "combat": {
    "system": "attack_matrix",
    "initiative": "d6 per side (Gruppeninitiative)",
    "segments": true,
    "attack_resolution": "Angreifer-Klasse + Level → Attack-Matrix → Wuerfelergebnis vs Ziel-AC",
    "armor_class": {
      "direction": "descending",
      "unarmored": 10,
      "best": -10,
      "notes": "AC 10 (nackt) bis AC -10 (goettlich). Niedrigere AC = besserer Schutz. Gegenteil von 2e THAC0-System."
    },
    "notes": "1e verwendet Attack-Matrices statt THAC0. THAC0 existiert im DMG als optionale Abkuerzung, wird aber erst in 2e Standard. Segmente (1/10 Runde) bestimmen Spell-Casting-Zeiten und Waffengeschwindigkeiten."
  },
